{
	"compilerOptions": {
		"strict": true,
		"module": "commonjs",
		"target": "es2022",
		"lib": ["es2022"],
		"moduleResolution": "node",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"declaration": true,
		"outDir": "./dist",
		"rootDir": ".",
		"resolveJsonModule": true,
		"sourceMap": true
	},
	"include": [
		"nodes/**/*.ts",
		"credentials/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}